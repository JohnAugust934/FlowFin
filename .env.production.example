# ============================================================
#  FlowFin — modelo de configuração de PRODUÇÃO (Hostinger)
# ------------------------------------------------------------
#  Copie este arquivo para ".env" no servidor e preencha os
#  valores marcados com << ... >>. NÃO coloque segredos reais
#  neste arquivo de exemplo nem o publique no GitHub.
#  Depois de editar, rode:  php artisan key:generate
# ============================================================

APP_NAME=FlowFin
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Endereço completo do site COM https:// (HTTPS é obrigatório para o PWA/offline).
APP_URL=https://<<seudominio-ou-subdominio>>

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Em produção mantenha o log enxuto (warning) para não encher o disco.
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ---- Banco de dados MySQL da Hostinger (crie no hPanel > Bancos de Dados) ----
# Requer a extensão pdo_mysql habilitada no PHP do servidor.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=<<nome_do_banco>>
DB_USERNAME=<<usuario_do_banco>>
DB_PASSWORD=<<senha_do_banco>>

# ---- Sessão, fila e cache (hospedagem compartilhada: SEM Redis) ----
# Tudo no banco/arquivo, como exige a hospedagem compartilhada.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Fila no banco: o reset diário da "sequência" (streak) é despachado para cá
# e processado pelo cron único (php artisan schedule:run). NÃO use Redis.
QUEUE_CONNECTION=database

# Cache em arquivo (não há Redis na hospedagem compartilhada).
CACHE_STORE=file

# ---- E-mail (SMTP da Hostinger) — necessário para a verificação de cadastro ----
# Crie uma caixa de e-mail no hPanel (E-mails) e use as credenciais dela.
# Porta 465 = SSL  |  porta 587 = TLS.
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USERNAME=<<seu-email@seudominio.com>>
MAIL_PASSWORD=<<senha-da-caixa-de-email>>
MAIL_FROM_ADDRESS="nao-responder@<<seudominio.com>>"
MAIL_FROM_NAME="FlowFin"

VITE_APP_NAME="${APP_NAME}"
